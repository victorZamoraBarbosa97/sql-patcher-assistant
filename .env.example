# Variables de Entorno de Ejemplo

# URL del backend de Sispro
VITE_SISPRO_API_URL="https://url.del.api.de.produccion"

# Poner en "true" para forzar datos simulados y evitar errores de red en el portafolio
VITE_FORCE_MOCK_DATA="true"

# Credenciales de Firebase
VITE_FIREBASE_API_KEY="TU_API_KEY_DE_FIREBASE"
VITE_FIREBASE_AUTH_DOMAIN="tu-proyecto.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="tu-id-de-proyecto"
VITE_FIREBASE_STORAGE_BUCKET="tu-proyecto.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="TU_SENDER_ID"
VITE_FIREBASE_APP_ID="TU_APP_ID"
